## 2. Consolidated Code

### 2.1 tcwt.h
```c
#ifndef __TCWT__
#define __TCWT__

struct tcwt_parameters {
  double C0;
  double kappa;
  double alpha;
  double a0;
  double gamma;
  double Omega_min;
  double beta_tcwt;     // = alpha / C0
  double k_g;           // h/Mpc
  double p_smooth;      // smoothing exponent (~1.6)
  int tcwt_on;
};

int tcwt_init(struct tcwt_parameters *tcp);
int tcwt_background_step(double a, double H, double Omega, double *dOmega,
                         struct tcwt_parameters *tcp);
double tcwt_Geff(double k, double a, struct tcwt_parameters *tcp);

#endif

#include "tcwt.h"
#include "common.h"
#include <math.h>

int tcwt_init(struct tcwt_parameters *tcp) {
  tcp->beta_tcwt = tcp->alpha / tcp->C0;
  tcp->k_g       = 0.12;      // tune this
  tcp->p_smooth  = 1.6;       // recommended
  return _SUCCESS_;
}

#include "tcwt.h"
#include "common.h"
#include <math.h>

int tcwt_background_step(double a, double H, double Omega, double *dOmega,
                         struct tcwt_parameters *tcp) {
  *dOmega = -tcp->gamma * H * (Omega - tcp->Omega_min);
  return _SUCCESS_;
}

#include "tcwt.h"
#include "common.h"
#include <math.h>

double tcwt_Geff(double k, double a, struct tcwt_parameters *tcp) {
  if (!tcp->tcwt_on) return 1.0;
  double ratio = k / tcp->k_g;
  double T_k = 1.0 / (1.0 + pow(ratio, 2.0 * tcp->p_smooth));
  return T_k;   // G_eff = G * T_k
}

double G_eff = tcwt_Geff(k, a, tcp);

delta_m_ddot = -2.0 * H * delta_m_dot
               - 4.0 * _PI_ * G * G_eff * rho_m * delta_m
               - tcp->beta_tcwt * pow(k, 4.0) / pow(a, 4.0) * delta_m;

